# Copy to .env for local `netlify dev`, and set the same keys as
# Netlify site environment variables for the deployed site.

# Supabase project settings -> API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# The "secret" key (sb_secret_...) - Supabase's current name for what
# used to be called the service_role key. Never expose this to the browser.
SUPABASE_SECRET_KEY=

# Any long random string - used to sign session JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Base URL of the deployed site (used for absolute links where needed).
BASE_URL=http://localhost:8888
